{
  "name": "wynn-api-types",
  "version": "3.7.2",
  "description": "TypeScript types for the Wynncraft API",
  "author": "ILikePlayingGames",
  "license": "MIT",
  "type": "module",
  "files": [
    "index.d.ts",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "npx openapi-typescript schemas/unified.json -o index.d.ts && npx eslint --fix",
    "download-spec": "node scripts/download-spec.ts",
    "merge": "node scripts/merge.ts"
  },
  "engines": {
    "node": ">=25",
    "npm": ">=11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=25",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "eslint": "^10.4.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@fastify/deepmerge": "^3.2.1"
  }
}
